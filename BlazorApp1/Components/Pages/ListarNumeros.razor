@page "/listarnumeros"
@rendermode InteractiveServer

<div class="container py-4">
    <div class="card shadow-sm p-4" style="max-width: 700px;">
        <h2 class="mb-4">Clasificador de Pares e Impares</h2>

        <div class="row mb-3">
            <div class="col-md-6">
                <label>Primer número:</label>
                <input type="number" class="form-control" @bind="num1" />
            </div>
            <div class="col-md-6">
                <label>Segundo número:</label>
                <input type="number" class="form-control" @bind="num2" />
            </div>
        </div>

        <button class="btn btn-success mb-4" @onclick="CalcularListas">Calcular</button>

        <div class="row">
            <div class="col-md-6">
                <div class="p-3 border bg-light">
                    <h5>Números Pares</h5>
                    <p>@string.Join(", ", listaPares)</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border bg-light">
                    <h5>Números Impares</h5>
                    <p>@string.Join(", ", listaImpares)</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int num1;
    private int num2;
    private List<int> listaPares = new List<int>();
    private List<int> listaImpares = new List<int>();

    private void CalcularListas()
    {
        // Limpiamos las listas anteriores
        listaPares.Clear();
        listaImpares.Clear();

        // 1. Determinar cuál es el menor y cuál es el mayor
        int inicio;
        int fin;

        if (num1 < num2)
        {
            inicio = num1;
            fin = num2;
        }
        else
        {
            inicio = num2;
            fin = num1;
        }

        // 2. Recorrer los números desde el menor hasta el mayor
        for (int i = inicio; i <= fin; i++)
        {
            // 3. Clasificar si es par o impar
            if (i % 2 == 0)
            {
                // Es par (el residuo de dividir entre 2 es cero)
                listaPares.Add(i);
            }
            else
            {
                // Es impar
                listaImpares.Add(i);
            }
        }
    }
}